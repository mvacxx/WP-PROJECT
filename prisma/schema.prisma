generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  draft
  provisioning
  ready
  failed
  paused
}

enum InstallationType {
  vps
  shared_hosting
  cloud
  manual
}

enum ProvisioningMethod {
  ssh_wp_cli
  softaculous_api
  manual
}

enum ProvisioningStatus {
  pending
  running
  completed
  failed
}

enum WordpressConnectionStatus {
  unknown
  connected
  failed
}

enum ContentProvider {
  seowriting
  manual
  generic
}

enum ProviderJobStatus {
  queued
  processing
  completed
  failed
  unknown
}

enum TargetPublishMode {
  manual_review
  auto_publish
  scheduled
}

enum ContentJobStatus {
  pending
  sending_to_generation
  generated
  posted_to_wordpress
  review_pending
  published
  failed
}

enum LogLevel {
  debug
  info
  warn
  error
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Project {
  id                     String                    @id @default(cuid())
  name                   String
  domain                 String                    @unique
  niche                  String
  language               String
  desiredTheme           String?
  initialPages           Json?
  defaultPlugins         Json?
  installationType       InstallationType
  status                 ProjectStatus             @default(draft)
  wordpressConnection    WordpressConnectionStatus @default(unknown)
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt

  wordpressInstallations WordpressInstallation[]
  contentJobs            ContentJob[]
  logs                   SystemLog[]
}

model WordpressInstallation {
  id                       String             @id @default(cuid())
  projectId                String
  method                   ProvisioningMethod
  status                   ProvisioningStatus @default(pending)
  wpSiteUrl                String?
  wpAdminUrl               String?
  wpUsername               String?
  wpApplicationPasswordEnc String?
  sshHost                  String?
  sshPort                  Int?
  sshUsername              String?
  sshPrivateKeyEnc         String?
  timezone                 String?
  permalinkStructure       String?
  lastSyncAt               DateTime?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ContentJob {
  id                String            @id @default(cuid())
  projectId         String
  title             String
  keyword           String
  provider          ContentProvider
  providerJobId     String?
  providerStatus    ProviderJobStatus @default(unknown)
  targetPublishMode TargetPublishMode @default(manual_review)
  attemptCount      Int               @default(0)
  lastAttemptAt     DateTime?
  status            ContentJobStatus  @default(pending)
  wpPostId          Int?
  wpPostUrl         String?
  scheduledAt       DateTime?
  failureReason     String?
  providerPayload   Json?
  normalizedContent Json?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  logs    ContentLog[]

  @@index([projectId])
  @@index([status])
  @@index([providerStatus])
}

model ContentLog {
  id        String   @id @default(cuid())
  jobId     String
  level     LogLevel @default(info)
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  job ContentJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

model SystemLog {
  id        String   @id @default(cuid())
  projectId String?
  level     LogLevel @default(info)
  source    String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([source])
}
